# Copy this file to .env for local development.
# This file is a template and is NOT automatically loaded by the app.
# Docker Compose and the backend read values from .env.

ENVIRONMENT=development

# Optional: disable if you want to test real auth locally
 DEV_AUTO_ADMIN=true

# Set a real value in production
ADMIN_TOKEN=e00c8a2e363398e24ed3f26668166af4877da16387a70a6506ee5e7f9517c2b0

# Optional AI configuration
# OPENAI_API_KEY=your-key-here
# OPENAI_MODEL=gpt-4o

# Optional platform export configuration
# ARTIO_API_URL=https://your-artio-instance.example
# ARTIO_API_KEY=your-artio-api-key

# Optional crawl/runtime tuning
# MAX_CRAWL_DEPTH=3
# MAX_PAGES_PER_SOURCE=500
# CRAWL_DELAY_MS=1000
# PLAYWRIGHT_ENABLED=true
# CORS_ORIGINS=http://localhost:5173
