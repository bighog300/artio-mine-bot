# Copy this file to .env for local development.
# This file is a template and is NOT automatically loaded by the app.
# Docker Compose and the backend read values from .env.

ENVIRONMENT=development

# Optional: disable if you want to test real auth locally
# DEV_AUTO_ADMIN=true

# Set a real value in production
# ADMIN_API_TOKEN=your-secure-token

# Optional AI configuration
# OPENAI_API_KEY=your-key-here
# OPENAI_MODEL=gpt-4o

# Optional platform export configuration
# ARTIO_API_URL=https://your-artio-instance.example
# ARTIO_API_KEY=your-artio-api-key

# Optional crawl/runtime tuning
# MAX_CRAWL_DEPTH=3
# MAX_PAGES_PER_SOURCE=500
# CRAWL_DELAY_MS=1000
# PLAYWRIGHT_ENABLED=true
# CORS_ORIGINS=http://localhost:5173

# Docker Compose host port overrides (optional, useful when running multiple stacks)
# API_HOST_PORT=8765
# FRONTEND_HOST_PORT=5173

# Optional Postgres credentials for docker-compose service
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=artio

# Frontend API endpoint used by Docker frontend container
# VITE_API_BASE_URL=http://localhost:8765
