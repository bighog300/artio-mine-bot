# Artio Miner — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-...

# ── Database ──────────────────────────────────────────────────────────────────
# Production — PostgreSQL (recommended, e.g. Neon serverless):
# IMPORTANT: async SQLAlchemy requires asyncpg driver.
# Required format: postgresql+asyncpg://user:password@host:5432/dbname?sslmode=require
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.neon.tech/artio?sslmode=require
# Invalid formats (do not use): postgresql://..., postgresql+psycopg2://...
#
# Local development — SQLite (zero-config fallback, used when DATABASE_URL is unset):
# DATABASE_URL=sqlite+aiosqlite:///./data/miner.db

# ── Optional ──────────────────────────────────────────────────────────────────

# AI model (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Artio platform export (needed for the export feature)
ARTIO_API_URL=https://your-artio-instance.vercel.app
ARTIO_API_KEY=your-artio-api-key

# Crawl settings
MAX_CRAWL_DEPTH=3
MAX_PAGES_PER_SOURCE=500
CRAWL_DELAY_MS=1000

# Browser (set to false to disable Playwright JS rendering)
PLAYWRIGHT_ENABLED=true

# CORS origins for the frontend (comma-separated, no spaces)
# API is exposed on host port 8765
CORS_ORIGINS=http://localhost:5173
