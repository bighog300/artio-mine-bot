{
  "buildCommand": "cd frontend && npm install && VITE_API_URL= npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@4.1.4",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
